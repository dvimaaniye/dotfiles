#!/usr/bin/env bash

. "$SETUP_PATH/lib"

pacman_pkgs=()
for f in "$SETUP_PATH/data/pacman/"*.txt; do
    [[ -e $f ]] || continue
    mapfile -t pkgs < <(read_list "$f")
    pacman_pkgs+=("${pkgs[@]}")
done

yay_pkgs=()
for f in "$SETUP_PATH/data/yay/"*.txt; do
    [[ -e $f ]] || continue
    mapfile -t pkgs < <(read_list "$f")
    yay_pkgs+=("${pkgs[@]}")
done

if (( ${#pacman_pkgs[@]} > 0 )); then
    if (( FORCE == 1 )) || ! pacman -Qi "${pacman_pkgs[@]}" &>/dev/null; then
        log_step "Installing all pacman packages..."
        sudo pacman -S --needed --noconfirm "${pacman_pkgs[@]}" || {
            log_warn "Bulk pacman failed. Retrying individually..."
            for p in "${pacman_pkgs[@]}"; do
                sudo pacman -S --needed --noconfirm "$p" || log_error "Failed: $p"
            done
        }
    else
        log_skip "All pacman packages already installed"
    fi
fi

if (( ${#yay_pkgs[@]} > 0 )); then
    if (( FORCE == 1 )) || ! pacman -Qi "${yay_pkgs[@]}" &>/dev/null; then
        log_step "Installing all AUR packages..."
        yay -S --needed --noconfirm "${yay_pkgs[@]}" || {
            log_warn "Bulk AUR failed. Retrying individually..."
            for p in "${yay_pkgs[@]}"; do
                yay -S --needed --noconfirm "$p" || log_error "Failed: $p"
            done
        }
    else
        log_skip "All AUR packages already installed"
    fi
fi

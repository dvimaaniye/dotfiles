#!/usr/bin/env bash

. "$SETUP_PATH/lib/env"

log_step 'Installing Nerd Fonts...'

repo_url='https://github.com/ryanoasis/nerd-fonts'
font_dir="$HOME/.local/share/fonts"

mapfile -t fonts < <(read_list "$SETUP_PATH/data/fonts.txt")

if (( ${#fonts[@]} == 0 )); then
	log_skip 'No fonts to install'
	exit 0
fi

if ! has_cmd curl; then
	log_error 'curl not found, cannot fetch latest font version'
	exit 1
fi

if ! has_cmd tar; then
	log_error 'tar not found, cannot extract font archive'
	exit 1
fi

log_info 'Fetching latest nerd-fonts version...'
api_url='https://api.github.com/repos/ryanoasis/nerd-fonts/releases/latest'
raw=$(curl -s "$api_url")
tag=${raw#*\"tag_name\": \"}
tag=${tag%%\"*}
version="${tag#v}"

ensure_dir "$font_dir"

for font in "${fonts[@]}"; do
	dest="$font_dir/$font"
	if [[ -d "$dest" ]] && (( FORCE != 1 )); then
		log_skip "Font $font"
		continue
	fi

	log_info "Downloading $font v$version..."
	url="$repo_url/releases/download/v$version/$font.tar.xz"
	archive="/tmp/$font.tar.xz"

	if curl -Lso "$archive" "$url"; then
		mkdir -p "$dest"
		tar -xf "$archive" -C "$dest" || {
			log_error "Failed to extract $font"
			continue
		}
		rm "$archive"
		log_ok "Installed $font"
	else
		log_error "Failed to download $font"
		continue
	fi
done

log_info 'Refreshing font cache...'
fc-cache -f "$font_dir" || log_warn 'fc-cache failed'

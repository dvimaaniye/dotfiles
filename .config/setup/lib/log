#!/usr/bin/env bash

green='\033[0;32m'
yellow='\033[1;33m'
red='\033[0;31m'
cyan='\033[0;36m'
bold='\033[1m'
nc='\033[0m'

log_info() {
	printf "${green}[INFO]${nc}  %s\n" "$1"
}

log_warn() {
	printf "${yellow}[WARN]${nc}  %s\n" "$1"
}

log_error() {
	printf "${red}[ERROR]${nc} %s\n" "$1"
}

log_step() {
	printf "\n${bold}${cyan}==> %s${nc}\n" "$1"
}

log_ok() {
	printf "${green}  ✓${nc} %s\n" "$1"
}

log_skip() {
	printf "${yellow}  ~${nc} %s (already done)\n" "$1"
}
